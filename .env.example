EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password-or-app-password
EMAIL_TO=recipient@example.com
EMAIL_APPROVAL_SECRET=replace-with-a-long-random-secret

# OpenAI content generation
OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4.1-mini
# WORK_CONTEXT_URL=https://www.shozibabbas.com/work
# REVIEW_RSS_FEED_URL=https://dev.to/feed

# Optional SMTP overrides (if not using Gmail service auto-detection)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false

# IMAP inbox polling for reply-based approvals
# IMAP_USER defaults to EMAIL_USER when omitted
# IMAP_PASS defaults to EMAIL_PASS when omitted
IMAP_HOST=imap.example.com
# IMAP_PORT=993
# IMAP_SECURE=true
# IMAP_USER=your-email@example.com
# IMAP_PASS=your-email-password-or-app-password

# Optional cron schedule for approval-reply polling
# EMAIL_APPROVAL_POLL_CRON=*/1 * * * *

# Web admin server
# WEB_PORT=60396
