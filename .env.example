# LinkedIn Bot Desktop App Configuration

# OpenAI API Configuration
# Users must provide their own OpenAI API key in the app settings
# OPENAI_API_KEY is NOT set here - app will prompt user to enter it
OPENAI_MODEL=gpt-4o-mini

# Purchase URL for license key acquisition
PURCHASE_URL=https://temp-purchase-link.example.com/linkedin-bot

# App Settings
# These are typically set through the app UI, not here
# NODE_ENV=development
