{
  "name": "linkedin-human-loop-cli",
  "version": "1.0.0",
  "description": "Human-in-the-loop LinkedIn posting CLI for macOS using Playwright",
  "main": "scheduler.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "login": "node login.js",
    "add-post": "node add-post.js",
    "post-now": "node post-now.js",
    "post-now:auto": "node post-now-auto.js",
    "start": "node scheduler.js",
    "start:all": "node launch-agent-entry.js",
    "web:build": "vite build",
    "web:start": "npm run web:build && node web-server.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "imapflow": "^1.0.181",
    "mailparser": "^3.7.2",
    "node-cron": "^3.0.3",
    "node-notifier": "^10.0.1",
    "nodemailer": "^6.9.15",
    "playwright": "^1.52.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "vite": "^5.4.10"
  }
}
