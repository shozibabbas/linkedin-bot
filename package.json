{
  "name": "linkedin-bot-desktop",
  "version": "1.0.0",
  "description": "LinkedIn automation desktop app with morning scheduling, posts module, and licensing",
  "main": "main.js",
  "type": "commonjs",
  "homepage": "./",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "electron .",
    "start": "vite build && electron .",
    "build": "vite build && electron-builder",
    "build:mac": "vite build && electron-builder --mac",
    "build:win": "vite build && electron-builder --win",
    "generate-license": "node generate-license.js",
    "video:studio": "remotion studio remotion/Root.jsx",
    "video:render:1x1": "remotion render remotion/Root.jsx LinkedInBotIntroSquare out/linkedin-bot-intro-1x1.mp4",
    "video:render:1x1:muted-captioned": "remotion render remotion/Root.jsx LinkedInBotIntroSquare out/linkedin-bot-intro-1x1-muted-captioned.mp4 --props='{\"muted\":true}'",
    "video:render:1x1:music": "remotion render remotion/Root.jsx LinkedInBotIntroSquare out/linkedin-bot-intro-1x1-music.mp4 --props='{\"muted\":false,\"audioSrc\":\"video-assets/audio/main.mp3\"}'",
    "video:render:16x9": "remotion render remotion/Root.jsx LinkedInBotIntroLandscape out/linkedin-bot-intro-16x9.mp4",
    "video:render:9x16": "remotion render remotion/Root.jsx LinkedInBotIntroPortrait out/linkedin-bot-intro-9x16.mp4"
  },
  "build": {
    "appId": "com.shozibabbas.linkedin-bot",
    "productName": "LinkedIn Bot",
    "icon": "assets/icon.png",
    "files": [
      "main.js",
      "preload.js",
      "*.js",
      "dist/**/*",
      "assets/**/*",
      "node_modules/**/*",
      ".env"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist-app"
    },
    "mac": {
      "icon": "assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "dependencies": {
    "axios": "^1.7.7",
    "better-sqlite3": "^11.9.1",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.4.5",
    "electron-store": "^8.2.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.6",
    "playwright": "^1.52.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.452",
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8",
    "remotion": "^4.0.452",
    "vite": "^5.4.10"
  }
}
